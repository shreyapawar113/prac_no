CREATE FUNCTION busesPimpriChinchwad()
RETURNS VARCHAR(500)
DETERMINISTIC
BEGIN
    DECLARE result VARCHAR(500);

    SELECT GROUP_CONCAT(B.bus_no, ' ', B.capacity, ' ', B.depot_name)
    INTO result
    FROM Bus B
    JOIN Bus_Route BR ON B.bus_no = BR.bus_no
    JOIN Route R ON BR.route_no = R.route_no
    WHERE R.source = 'Pimpri' AND R.destination = 'Chinchwad';

    RETURN result;
END $$

