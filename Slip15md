#include <iostream>
using namespace std;

class time
{
private:
    int h, m, s;

public:
    void settime(int hh, int mm, int ss)
    {
        h = hh;
        m = mm;
        s = ss;
    }

    void ShowTime()
    {
        cout << h << ":" << m << ":" << s << endl;
    }

    time add(time t)
    {
        time temp;

        temp.s = s + t.s;
        temp.m = m + t.m + temp.s / 60;
        temp.s = temp.s % 60;

        temp.h = h + t.h + temp.m / 60;
        temp.m = temp.m % 60;

        return temp;
    }
};

int main()
{
    time t1, t2, t3;

    t1.settime(2, 45, 50);
    t2.settime(3, 20, 30);

    t3 = t1.add(t2);

    cout << "Time 1: ";
    t1.ShowTime();

    cout << "Time 2: ";
    t2.ShowTime();

    cout << "After Addition: ";
    t3.ShowTime();

    return 0;
